{
    "version": "0.9.5",
    "build": "2026.04.06",
    "release_date": "2026-04-06",
    "changelog": [
        "Client Portal plugin — self-service for hosting customers (VMs, console, snapshots, 2FA)",
        "Public Status Page plugin — cluster health on monitoring screens with URL auth key (#126)",
        "Plugin config editor in Settings UI (JSON textarea with validation)",
        "Integrated syslog server — UDP/TCP on port 1514 with log viewer (PR #257, gyptazy)",
        "External ACME CA support — custom ACME directory URLs e.g. StepCA (#249, PR #258, gyptazy)",
        "Markdown VM descriptions with Edit/Preview toggle (PR #263, newtscamander2)",
        "Inline tag selector with Proxmox tag dropdown + validation (PR #263)",
        "Node and tag filter dropdowns in Resource Management (PR #263)",
        "DNS name validation for VMs before API call (PR #263)",
        "Tags displayed in compact/card view",
        "portal_only user flag — restrict login to /portal only",
        "VNC console audit logging with user attribution in task bar",
        "Portal customer actions visible in admin task bar (start/stop/snapshot/reboot)",
        "fix: setReconfigureCluster prop missing in sidebar (#261, newtscamander2)",
        "fix: OIDC skip JWT verification not persisted across sessions (#188)",
        "fix: List view table too wide — removed IP column in modern layout, compacted RAM/disk",
        "security: timing-safe auth key comparison for status page",
        "security: TOTP rate limit tightened (3 attempts/2min)",
        "security: absolute session timeout (24h max)",
        "security: admin password change revokes all sessions",
        "security: plugin path traversal prevention",
        "security: file upload magic byte validation",
        "security: API token permission escalation fix",
        "security: plugin trust warnings for non-PegaProx authors",
        "security: DB encryption key permissions enforced on startup"
    ],
